# Popular Peptides — Environment Variables
# Copy this to .env.local and fill in your values

# Site
NEXT_PUBLIC_SITE_URL=https://popularpeptides.ca
NEXT_PUBLIC_SITE_NAME=Popular Peptides

# Email (for order notifications — use Gmail App Password or SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sales@popularpeptides.ca
SMTP_PASS=your_app_password_here
ORDER_EMAIL=sales@popularpeptides.ca

# Mobopay (when ready — plug in your credentials)
# NEXT_PUBLIC_MOBOPAY_MERCHANT_ID=
# MOBOPAY_API_KEY=
# NEXT_PUBLIC_MOBOPAY_ENDPOINT=https://api.mobopay.com

# Optional: Admin password for simple order management
ADMIN_SECRET=change_this_to_a_strong_secret

# Brevo CRM (house-call intake → feeds /api/house-call-intake)
# API key: Brevo → Settings → SMTP & API → API Keys (starts with "xkeysib-")
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxx
# Numeric ID of the "House Calls" contact list in Brevo
BREVO_HOUSE_CALL_LIST_ID=

# Analytics
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx
NEXT_PUBLIC_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbwnfcH0gi_nZBDpAO8MUHKs_dWNwY51T7avkF_jNlqZByvbngPheELyV2xCwSZn0_i2zA/exec
